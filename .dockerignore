# Keep the Docker build context minimal — `target/` alone is ~1 GB.
/target
/.git
/.github
/.idea
/.vscode
/docs
# Keep examples/ out by default to keep the build context small, but
# un-ignore examples/todo/ — the CLI's `init.rs` bundles it via
# `include_dir!` for `pg-web init --template todo`. Without it, the
# CLI build's proc-macro panics during F.3's image bake.
/examples/*
!/examples/todo
/scripts
/LICENSE-*
Cargo.lock.bak
*.log
.DS_Store
# Scaffolded test apps created by pg-web init (e.g. during local smoke runs)
/tmp
